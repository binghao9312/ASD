rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isSuperAdmin() {
      return get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.roleId == 'superadmin';
    }

    function isAdmin() {
      let u = get(/databases/$(database)/documents/users/$(request.auth.token.email)).data;
      return u.role == 'admin' || u.roleId == 'superadmin' || u.roleId == 'admin';
    }

    match /users/{userId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.token.email == userId;
      allow update: if request.auth != null && (isSuperAdmin() || (request.auth.token.email == userId && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'roleId', 'status'])));
      allow delete: if request.auth != null && isSuperAdmin();
    }

    match /settings/{docId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && isSuperAdmin();
    }
    
    match /luggages/{luggageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.token.email)).data.status == 'approved';
      allow delete: if request.auth != null && (isAdmin() || resource.data.checkerEmail == request.auth.token.email);
      allow update: if request.auth != null && (isAdmin() || resource.data.checkerEmail == request.auth.token.email);
    }
  }
}
